import { RegisterView } from "views/register-view.slint";
import { AboutDialog } from "components/about-dialog.slint";

export component AppWindow inherits Window {
    title: "Rust Agent Foundation";
    preferred-width: 480px;
    preferred-height: 320px;
    min-width: 360px;
    min-height: 240px;

    in-out property <string> greeting: "Hello from Slint";
    in-out property <string> status-message: "Ready";

    callback register-user(string);
    callback request-exit();

    MenuBar {
        Menu {
            title: "File";
            MenuItem {
                title: "New...";
                enabled: false;
            }
            MenuItem {
                title: "Open...";
                enabled: false;
            }
            MenuSeparator {}
            MenuItem {
                title: "Exit";
                activated => {
                    root.request-exit();
                }
            }
        }
        Menu {
            title: "Help";
            MenuItem {
                title: "About Rust Agent Foundation";
                activated => {
                    about-dialog.show();
                }
            }
        }
    }

    about-dialog := AboutDialog {
        anchor-width: root.width;
        anchor-height: root.height;
    }

    RegisterView {
        width: 100%;
        height: 100%;
        greeting <=> root.greeting;
        status-message <=> root.status-message;
        register-user(name) => {
            root.register-user(name);
        }
    }
}
