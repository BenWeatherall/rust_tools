import { RegisterView } from "views/register-view.slint";

export component AppWindow inherits Window {
    title: "Rust Agent Foundation";
    preferred-width: 480px;
    preferred-height: 320px;

    in-out property <string> greeting: "Hello from Slint";
    in-out property <string> status-message: "Ready";

    callback register-user(string);

    RegisterView {
        greeting <=> root.greeting;
        status-message <=> root.status-message;
        register-user(name) => {
            root.register-user(name);
        }
    }
}
